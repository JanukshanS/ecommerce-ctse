# =============================================================
# ECOMMERCE MICROSERVICES - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore and will NEVER be committed to git.
# =============================================================

# ---------------------------------------------------------------
# JWT CONFIGURATION
# Must be the SAME secret across all services (shared signing key).
# Generate a strong random string in production (min 64 hex chars).
# ---------------------------------------------------------------
JWT_SECRET=your-strong-jwt-secret-here-minimum-64-characters-replace-this
JWT_EXPIRATION_MS=86400000

# ---------------------------------------------------------------
# Spring active profile
# Use 'docker' when running inside Docker Compose.
# ---------------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker

# ---------------------------------------------------------------
# Note: MongoDB URIs and inter-service URLs are configured
# directly in docker-compose.yml per-service since each service
# needs a different database name (authdb, catalogdb, etc.)
#
# For cloud deployment (Azure Container Apps / AWS ECS), set these
# as container environment variables or use a secrets manager:
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
#   JWT_SECRET=your-secret
# ---------------------------------------------------------------
