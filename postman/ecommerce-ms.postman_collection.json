    {
      "name": "05 - Payment Service",
      "description": "Payment processing and refunds via /api/payments",
      "item": [
        {
          "name": "Process Payment",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Create a fresh order first so we have a valid orderId to pay",
                  "// In practice, use the orderId captured from 04-Create Order"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Payment processed', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('string').and.not.empty;",
                  "    pm.expect(body.transactionId).to.be.a('string').and.not.empty;",
                  "    pm.expect(['SUCCESS','FAILED']).to.include(body.status);",
                  "    pm.environment.set('paymentId', body.id);",
                  "    pm.collectionVariables.set('paymentId', body.id);",
                  "    console.log('Payment status:', body.status);",
                  "    console.log('Transaction ID:', body.transactionId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"amount\": 389.97,\n  \"method\": \"CREDIT_CARD\",\n  \"description\": \"Payment for order {{orderId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/process",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "process"]
            }
          }
        },
