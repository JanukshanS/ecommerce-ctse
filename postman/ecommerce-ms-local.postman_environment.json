{
  "id": "ecommerce-ms-local-env",
  "name": "ECommerce Local",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "default",
      "enabled": true,
      "description": "API Gateway base URL. Change to your cloud ALB URL for production testing."
    },
    {
      "key": "token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "JWT token — auto-populated by Register or Login requests"
    },
    {
      "key": "userId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated after register/login"
    },
    {
      "key": "productId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated after Create Product"
    },
    {
      "key": "productId2",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated after Create Second Product"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated after Create Order"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated after Process Payment"
    }
  ],
  "_postman_variable_scope": "environment",
  "info": {
    "description": "Local development environment for ECommerce Microservices.\n\nFor cloud testing, change baseUrl to your AWS ALB DNS name:\n  https://<alb-dns-name>.elb.amazonaws.com"
  }
}
